{
  "realm": "nexuspay",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full access to all NexusPay operations"
      },
      {
        "name": "operator",
        "description": "Create payments, view all resources, initiate refunds"
      },
      {
        "name": "viewer",
        "description": "Read-only access to all resources"
      }
    ]
  },
  "clients": [
    {
      "clientId": "nexuspay-api",
      "name": "NexusPay API",
      "enabled": true,
      "publicClient": false,
      "secret": "nexuspay-api-secret",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:8090/*"],
      "webOrigins": ["http://localhost:8090"],
      "defaultClientScopes": ["openid", "profile", "email"],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin@nexuspay.test",
      "email": "admin@nexuspay.test",
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "test123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "operator@nexuspay.test",
      "email": "operator@nexuspay.test",
      "enabled": true,
      "firstName": "Operator",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "test123",
          "temporary": false
        }
      ],
      "realmRoles": ["operator"]
    },
    {
      "username": "viewer@nexuspay.test",
      "email": "viewer@nexuspay.test",
      "enabled": true,
      "firstName": "Viewer",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "test123",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
