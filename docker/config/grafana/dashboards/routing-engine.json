{
  "dashboard": {
    "id": null,
    "uid": "nexuspay-routing",
    "title": "NexusPay - Smart Routing Engine",
    "tags": ["nexuspay", "routing"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "psp",
          "type": "query",
          "query": "label_values(nexuspay_routing_decisions_total, psp)",
          "refresh": 2,
          "multi": true,
          "includeAll": true,
          "current": { "text": "All", "value": "$__all" }
        },
        {
          "name": "strategy",
          "type": "query",
          "query": "label_values(nexuspay_routing_decisions_total, strategy)",
          "refresh": 2,
          "multi": true,
          "includeAll": true,
          "current": { "text": "All", "value": "$__all" }
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Routing Decisions per Second",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(nexuspay_routing_decisions_total{strategy=~\"$strategy\"}[1m])) by (strategy)",
            "legendFormat": "{{ strategy }}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "ops" }
        }
      },
      {
        "id": 2,
        "title": "Auth Rate by PSP",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "nexuspay_routing_psp_auth_rate{psp=~\"$psp\"} * 100",
            "legendFormat": "{{ psp }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 70 },
                { "color": "green", "value": 90 }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Routing Decision Latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(nexuspay_routing_decision_latency_ms_bucket[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(nexuspay_routing_decision_latency_ms_bucket[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(nexuspay_routing_decision_latency_ms_bucket[5m])) by (le))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "ms" } }
      },
      {
        "id": 4,
        "title": "Cascade Depth Distribution",
        "type": "barchart",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum(increase(nexuspay_routing_cascade_attempts_total[1h])) by (depth)",
            "legendFormat": "Depth {{ depth }}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Cascade Trigger Rate",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(nexuspay_routing_cascades_triggered_total[5m])) / sum(rate(nexuspay_routing_decisions_total[5m])) * 100",
            "legendFormat": "Cascade %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 25 }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "PSP Latency (p95) by Connector",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "nexuspay_routing_psp_latency_p95_ms{psp=~\"$psp\"}",
            "legendFormat": "{{ psp }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1000 },
                { "color": "red", "value": 3000 }
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Circuit Breaker State",
        "type": "state-timeline",
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "nexuspay_routing_circuit_breaker_open{psp=~\"$psp\"}",
            "legendFormat": "{{ psp }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
              { "type": "value", "options": { "1": { "text": "OPEN", "color": "red" } } },
              { "type": "value", "options": { "2": { "text": "HALF-OPEN", "color": "yellow" } } }
            ]
          }
        }
      },
      {
        "id": 8,
        "title": "Routing Failures by Reason",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 24 },
        "targets": [
          {
            "expr": "sum(increase(nexuspay_routing_failures_total[1h])) by (reason)",
            "legendFormat": "{{ reason }}"
          }
        ]
      },
      {
        "id": 9,
        "title": "A/B Test Traffic Split",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 24 },
        "targets": [
          {
            "expr": "sum(increase(nexuspay_routing_decisions_total{ab_test_group!=\"\"}[1h])) by (ab_test_group)",
            "legendFormat": "Group {{ ab_test_group }}"
          }
        ]
      },
      {
        "id": 10,
        "title": "Cost per Transaction by PSP",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
        "targets": [
          {
            "expr": "nexuspay_routing_psp_effective_fee{psp=~\"$psp\"}",
            "legendFormat": "{{ psp }} ({{ currency }})"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "currencyUSD" }
        }
      },
      {
        "id": 11,
        "title": "PSP Selection Distribution (1h)",
        "type": "barchart",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
        "targets": [
          {
            "expr": "sum(increase(nexuspay_routing_decisions_total[1h])) by (psp)",
            "legendFormat": "{{ psp }}"
          }
        ]
      },
      {
        "id": 12,
        "title": "Decline Code Heatmap (Soft vs Hard)",
        "type": "table",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
        "targets": [
          {
            "expr": "topk(15, sum(increase(nexuspay_routing_decline_codes_total[1h])) by (code, type))",
            "legendFormat": "{{ code }} ({{ type }})",
            "format": "table",
            "instant": true
          }
        ]
      }
    ]
  }
}
