# NexusPay Local Development Environment
# All values are safe defaults for local development.
# NEVER use these values in production.

# HyperSwitch
HYPERSWITCH_ADMIN_API_KEY=admin_api_key
HYPERSWITCH_API_KEY=dev_api_key_for_local
HYPERSWITCH_BASE_URL=http://hyperswitch-router:8080

# NexusPay Database
NEXUSPAY_DB_URL=jdbc:postgresql://nexuspay-pg:5432/nexuspay
NEXUSPAY_DB_USER=nexuspay
NEXUSPAY_DB_PASSWORD=nexuspay_local

# Keycloak
KEYCLOAK_URL=http://keycloak:8180
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Valkey
VALKEY_URL=redis://valkey:6379

# Schema Registry (Sprint 3.4)
SCHEMA_REGISTRY_URL=http://schema-registry:8081
