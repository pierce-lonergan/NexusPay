# docker/docker-compose.override.yml.example
# ---------------------------------------------------------------------------
# To remap HOST ports and dodge collisions, PREFER THE ENV-VAR ROUTE.
#
# docker-compose.lite.yml already templates every host port with a default
# equal to the full-compose value:
#   ${NEXUSPAY_PG_PORT:-5432}  ${KAFKA_PORT:-9092}  ${KAFKA_HOST_PORT:-29092}
#   ${VALKEY_PORT:-6379}       ${KEYCLOAK_PORT:-8180}
# Set those in a docker/.env-style file (or your shell) and the host binding is
# REPLACED cleanly:
#   NEXUSPAY_PG_PORT=15432 KAFKA_PORT=19092 KAFKA_HOST_PORT=39092 \
#   VALKEY_PORT=16379 KEYCLOAK_PORT=18180 \
#     docker compose -f docker/docker-compose.lite.yml up -d
#
# WARNING -- this override file is ILLUSTRATIVE ONLY and will DOUBLE-BIND.
# Compose merges the `ports` list ADDITIVELY across `-f` files: short-form port
# strings are concatenated as unique entries, NOT replaced. So with
#   docker compose -f docker/docker-compose.lite.yml \
#                  -f docker/docker-compose.override.yml up -d
# kafka ends up with BOTH the base 9092:9092 / 29092:29092 AND the override
# 19092:9092 / 39092:29092 -- all four bindings. The original colliding host
# port (9092, 5432, 6379, 8180) STAYS BOUND, so the very collision you were
# escaping still fails / double-binds. The env-var route above does not have
# this problem because it re-templates the single base entry rather than adding
# a second one. Use the env-var route; the service stanzas below are kept only
# to show the host:container mapping you'd be remapping.
#
# Either way, if you remap, update the matching `bootRun` env vars so the app
# reaches the moved services, e.g.:
#   KEYCLOAK_URL=http://localhost:18180        (issuer-uri host:port)
#   NEXUSPAY_DB_URL=jdbc:postgresql://localhost:15432/nexuspay
#   KAFKA_BOOTSTRAP_SERVERS=localhost:39092    (use the PLAINTEXT_HOST listener)
#   VALKEY_URL=redis://localhost:16379
# ---------------------------------------------------------------------------
services:
  nexuspay-pg:
    ports:
      - "15432:5432"          # default 5432

  kafka:
    ports:
      - "19092:9092"          # default 9092 (in-network listener)
      - "39092:29092"         # default 29092 (PLAINTEXT_HOST listener)

  valkey:
    ports:
      - "16379:6379"          # default 6379

  keycloak:
    ports:
      - "18180:8080"          # default 8180
