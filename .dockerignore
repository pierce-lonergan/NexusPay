# Keep the Docker build context lean + reproducible (DX-6).
# Exclude build outputs, VCS, caches, IDE files, and the TS SDK npm workspace —
# none are inputs to the Java :app bootJar build.

# Gradle / build outputs
**/build/
**/.gradle/
.gradle/

# Version control + CI
.git/
.github/

# Node / TypeScript SDK workspace (separate from the Gradle build)
checkout-sdk/
**/node_modules/

# IDE / editor
.idea/
.vscode/
*.iml

# OS cruft
.DS_Store

# Local env / secrets (never bake into an image)
.env
*.env
!docker/.env

# Docs + meta that don't affect the build
*.md
.perpetua/
docs/
