{
  "name": "@nexuspay/react",
  "version": "0.1.0",
  "description": "React components for NexusPay checkout integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@nexuspay/js": ">=0.1.0"
  },
  "devDependencies": {
    "react": "^18.3.0",
    "@types/react": "^18.3.0",
    "@nexuspay/js": "*",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "@testing-library/react": "^15.0.0",
    "jsdom": "^24.0.0"
  },
  "sideEffects": false,
  "license": "MIT"
}
