{
  "name": "@nexus-pay/react",
  "version": "0.1.1",
  "description": "React components for NexusPay checkout integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@nexus-pay/js": ">=0.1.0"
  },
  "devDependencies": {
    "react": "^18.3.0",
    "@types/react": "^18.3.0",
    "@nexus-pay/js": "*",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "@testing-library/react": "^15.0.0",
    "jsdom": "^24.0.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "nexuspay",
    "react",
    "payments",
    "checkout",
    "payment-elements",
    "hooks"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pierce-lonergan/NexusPay.git",
    "directory": "checkout-sdk/packages/react"
  },
  "homepage": "https://github.com/pierce-lonergan/NexusPay/tree/main/checkout-sdk/packages/react#readme",
  "bugs": {
    "url": "https://github.com/pierce-lonergan/NexusPay/issues"
  }
}
