{
  "name": "@nexus-pay/js",
  "version": "0.1.1",
  "description": "NexusPay.js — PCI-compliant card tokenization and payment elements",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.js",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "jsdom": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "nexuspay",
    "payments",
    "checkout",
    "card",
    "tokenization",
    "pci",
    "payment-elements"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pierce-lonergan/NexusPay.git",
    "directory": "checkout-sdk/packages/js"
  },
  "homepage": "https://github.com/pierce-lonergan/NexusPay/tree/main/checkout-sdk/packages/js#readme",
  "bugs": {
    "url": "https://github.com/pierce-lonergan/NexusPay/issues"
  }
}
